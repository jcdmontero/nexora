{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:analyze": "vite build --mode analysis",
        "dev": "vite",
        "preview": "vite preview",
        "test:e2e": "npx playwright test",
        "test:e2e:ui": "npx playwright test --ui",
        "test:e2e:report": "npx playwright show-report tests/e2e/reports",
        "auditoria": "npx playwright test --config=playwright.auditoria.config.ts",
        "auditoria:setup": "npx playwright test --config=playwright.auditoria.config.ts --project=auditoria-setup",
        "auditoria:smoke": "npx playwright test --config=playwright.auditoria.config.ts --grep @smoke",
        "auditoria:ui": "npx playwright test --config=playwright.auditoria.config.ts --ui",
        "auditoria:report": "npx playwright show-report tests/e2e/auditoria/reports",
        "auditoria:empresa1": "npx playwright test --config=playwright.auditoria.config.ts tests/e2e/auditoria/empresa1/",
        "auditoria:empresa2": "npx playwright test --config=playwright.auditoria.config.ts tests/e2e/auditoria/empresa2/"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "rollup-plugin-visualizer": "^5.14.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource-variable/geist": "^5.2.9",
        "@hookform/resolvers": "^5.1.1",
        "@inertiajs/react": "^3.4.0",
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-dropdown-menu": "^2.1.14",
        "@radix-ui/react-select": "^2.2.5",
        "@radix-ui/react-tabs": "^1.1.12",
        "@radix-ui/react-toast": "^1.2.14",
        "@radix-ui/react-tooltip": "^1.2.7",
        "@shadcn/ui": "^0.0.4",
        "@tailwindcss/vite": "^4.3.1",
        "@vitejs/plugin-react": "^6.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.4.0",
        "lucide-react": "^1.21.0",
        "react": "^19.2.7",
        "react-barcode": "^1.6.1",
        "react-currency-input-field": "^4.0.5",
        "react-dom": "^19.2.7",
        "react-hook-form": "^7.54.2",
        "recharts": "^3.8.1",
        "shadcn": "^4.11.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1",
        "tw-animate-css": "^1.4.0",
        "ziggy-js": "^2.6.2",
        "zod": "^4.4.3"
    }
}
